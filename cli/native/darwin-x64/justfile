default:
    @just --list

# Co-locate the CLI binary and the runtime shared library in the
# package. The cgo build sets the rpath to @loader_path, so the
# runtime resolves from the package directory at load time.
build:
    cp ../../gaffer gaffer
    cp ../../../runtime/Gaffer.Runtime/bin/Release/net10.0/osx-x64/publish/Gaffer.Runtime.dylib Gaffer.Runtime.dylib

# Remove build artifacts
clean:
    rm -f gaffer Gaffer.Runtime.dylib
