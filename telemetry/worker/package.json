{
	"name": "@kurrent/gaffer-telemetry-worker",
	"version": "0.0.0",
	"private": true,
	"description": "Cloudflare Worker that ingests gaffer telemetry envelopes, translates to PostHog's batch shape, and redirects the legacy notice routes to the docs site",
	"type": "module",
	"main": "src/index.ts",
	"scripts": {
		"gen-types": "wrangler types --env staging",
		"build": "pnpm run gen-types",
		"check": "pnpm run build && prettier --check . && tsc --noEmit",
		"fix": "prettier --write .",
		"test": "pnpm run build && vitest run && wrangler deploy --env staging --dry-run --outdir=.wrangler/dryrun",
		"dev": "wrangler dev --env staging",
		"deploy:staging": "wrangler deploy --env staging",
		"deploy:production": "wrangler deploy --env production"
	},
	"dependencies": {
		"@cfworker/json-schema": "^4.1.1"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.16.7",
		"@kurrent/gaffer-telemetry": "workspace:*",
		"@types/node": "^25.9.1",
		"prettier": "^3.8.3",
		"typescript": "^6.0.3",
		"vitest": "^4.1.7",
		"wrangler": "^4.93.0"
	}
}
