default:
    @just --list

# Run the Astro dev server.
dev:
    pnpm run dev

# Build the production site.
build:
    pnpm run build

# Preview the built site locally.
preview:
    pnpm run preview

# Type check the Astro project.
check:
    pnpm run check

# Astro has no built-in lint fixer; surface a no-op so the root
# `just fix` parallel doesn't fall over when this module is included.
fix:
    @echo "docs: no fix step"

# Build + deploy to staging. CI fires on docs-touching main pushes.
deploy-staging:
    CLOUDFLARE_ENV=staging pnpm run build
    pnpm exec wrangler deploy --env staging

# Build + deploy to production. CI fires at release. Hotfix escape
# hatch when run locally after `pnpm exec wrangler login`.
deploy-production:
    CLOUDFLARE_ENV=production pnpm run build
    pnpm exec wrangler deploy --env production

# Remove build artifacts.
clean:
    rm -rf dist .astro .wrangler
