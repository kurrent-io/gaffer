default:
    @just --list

# Render the notice (cli/TELEMETRY.md + editors/vscode/TELEMETRY.md ->
# src/notice.gen.ts) and generate worker-configuration.d.ts from
# wrangler.jsonc.
build:
    pnpm run --filter '@kurrent/gaffer-telemetry-worker' build

# Format check + type check.
check: build
    pnpm run --filter '@kurrent/gaffer-telemetry-worker' check

# Format.
fix:
    pnpm run --filter '@kurrent/gaffer-telemetry-worker' fix

# Run tests (vitest in the Workers runtime via @cloudflare/vitest-pool-workers).
test: build
    pnpm run --filter '@kurrent/gaffer-telemetry-worker' test

# Local dev server (wrangler dev).
dev: build
    pnpm run --filter '@kurrent/gaffer-telemetry-worker' dev

# Deploy to staging. Requires CLOUDFLARE_API_TOKEN in env. CI uses this
# path on every main push; manual invocation is fine too.
deploy-staging: build
    pnpm run --filter '@kurrent/gaffer-telemetry-worker' deploy:staging

# Deploy to production. Requires CLOUDFLARE_API_TOKEN in env. CI handles
# this from release.yml on the Version Packages PR merge; manual
# invocation is an escape hatch.
deploy-production: build
    pnpm run --filter '@kurrent/gaffer-telemetry-worker' deploy:production

# Remove build artifacts.
clean:
    @rm -rf src/notice.gen.ts worker-configuration.d.ts .wrangler dist
