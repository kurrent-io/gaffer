default:
    @just --list

# Build TypeScript
build:
    pnpm run build

# Run tests
test:
    pnpm run test

# Type check, lint, and format check
check:
    pnpm run check

# Run integration tests (requires KurrentDB)
test-integration:
    pnpm run test:integration

# Format code and apply lint fixes
fix:
    pnpm run fix

# Remove build artifacts
clean:
    rm -rf dist
