[
	{
		"name": "init and accumulate",
		"source": "fromAll().when({ $init() { return { count: 0 }; }, ItemAdded(s, e) { s.count++; return s; } })",
		"events": [
			{ "eventType": "ItemAdded", "streamId": "cart-1", "sequenceNumber": 0, "data": "{}", "isJson": true, "eventId": "00000000-0000-0000-0000-000000000000", "created": "2026-01-01T00:00:00Z" },
			{ "eventType": "ItemAdded", "streamId": "cart-1", "sequenceNumber": 1, "data": "{}", "isJson": true, "eventId": "00000000-0000-0000-0000-000000000000", "created": "2026-01-01T00:00:00Z" },
			{ "eventType": "ItemAdded", "streamId": "cart-1", "sequenceNumber": 2, "data": "{}", "isJson": true, "eventId": "00000000-0000-0000-0000-000000000000", "created": "2026-01-01T00:00:00Z" }
		],
		"expect": {
			"state": { "count": 3 }
		}
	},
	{
		"name": "access event data",
		"source": "fromAll().when({ $init() { return { total: 0 }; }, Deposited(s, e) { s.total += e.data.amount; return s; } })",
		"events": [
			{ "eventType": "Deposited", "streamId": "acc-1", "sequenceNumber": 0, "data": "{\"amount\":50}", "isJson": true, "eventId": "00000000-0000-0000-0000-000000000000", "created": "2026-01-01T00:00:00Z" },
			{ "eventType": "Deposited", "streamId": "acc-1", "sequenceNumber": 1, "data": "{\"amount\":30}", "isJson": true, "eventId": "00000000-0000-0000-0000-000000000000", "created": "2026-01-01T00:00:00Z" }
		],
		"expect": {
			"state": { "total": 80 }
		}
	},
	{
		"name": "access nested event data",
		"source": "fromAll().when({ $init() { return { name: '' }; }, UserUpdated(s, e) { s.name = e.data.user.name; return s; } })",
		"events": [
			{ "eventType": "UserUpdated", "streamId": "user-1", "sequenceNumber": 0, "data": "{\"user\":{\"name\":\"Alice\",\"age\":30}}", "isJson": true, "eventId": "00000000-0000-0000-0000-000000000000", "created": "2026-01-01T00:00:00Z" }
		],
		"expect": {
			"state": { "name": "Alice" }
		}
	},
	{
		"name": "unhandled events ignored",
		"source": "fromAll().when({ $init() { return { count: 0 }; }, Wanted(s, e) { s.count++; return s; } })",
		"events": [
			{ "eventType": "Wanted", "streamId": "s-1", "sequenceNumber": 0, "data": "{}", "isJson": true, "eventId": "00000000-0000-0000-0000-000000000000", "created": "2026-01-01T00:00:00Z" },
			{ "eventType": "Ignored", "streamId": "s-1", "sequenceNumber": 1, "data": "{}", "isJson": true, "eventId": "00000000-0000-0000-0000-000000000000", "created": "2026-01-01T00:00:00Z" },
			{ "eventType": "Wanted", "streamId": "s-1", "sequenceNumber": 2, "data": "{}", "isJson": true, "eventId": "00000000-0000-0000-0000-000000000000", "created": "2026-01-01T00:00:00Z" }
		],
		"expect": {
			"state": { "count": 2 }
		}
	},
	{
		"name": "$any catches all events",
		"source": "fromAll().when({ $init() { return { count: 0 }; }, $any(s, e) { s.count++; return s; } })",
		"events": [
			{ "eventType": "Foo", "streamId": "s-1", "sequenceNumber": 0, "data": "{}", "isJson": true, "eventId": "00000000-0000-0000-0000-000000000000", "created": "2026-01-01T00:00:00Z" },
			{ "eventType": "Bar", "streamId": "s-1", "sequenceNumber": 1, "data": "{}", "isJson": true, "eventId": "00000000-0000-0000-0000-000000000000", "created": "2026-01-01T00:00:00Z" },
			{ "eventType": "Baz", "streamId": "s-1", "sequenceNumber": 2, "data": "{}", "isJson": true, "eventId": "00000000-0000-0000-0000-000000000000", "created": "2026-01-01T00:00:00Z" }
		],
		"expect": {
			"state": { "count": 3 }
		}
	},
	{
		"name": "named handler takes priority over $any",
		"source": "fromAll().when({ $init() { return { specific: 0, other: 0 }; }, Specific(s, e) { s.specific++; return s; }, $any(s, e) { s.other++; return s; } })",
		"events": [
			{ "eventType": "Specific", "streamId": "s-1", "sequenceNumber": 0, "data": "{}", "isJson": true, "eventId": "00000000-0000-0000-0000-000000000000", "created": "2026-01-01T00:00:00Z" },
			{ "eventType": "Other", "streamId": "s-1", "sequenceNumber": 1, "data": "{}", "isJson": true, "eventId": "00000000-0000-0000-0000-000000000000", "created": "2026-01-01T00:00:00Z" }
		],
		"expect": {
			"state": { "specific": 1, "other": 1 }
		}
	},
	{
		"name": "foreachStream partitioning",
		"source": "fromCategory(\"cart\").foreachStream().when({ $init() { return { items: 0 }; }, ItemAdded(s, e) { s.items++; return s; } })",
		"events": [
			{ "eventType": "ItemAdded", "streamId": "cart-1", "sequenceNumber": 0, "data": "{}", "isJson": true, "eventId": "00000000-0000-0000-0000-000000000000", "created": "2026-01-01T00:00:00Z" },
			{ "eventType": "ItemAdded", "streamId": "cart-1", "sequenceNumber": 1, "data": "{}", "isJson": true, "eventId": "00000000-0000-0000-0000-000000000000", "created": "2026-01-01T00:00:00Z" },
			{ "eventType": "ItemAdded", "streamId": "cart-2", "sequenceNumber": 0, "data": "{}", "isJson": true, "eventId": "00000000-0000-0000-0000-000000000000", "created": "2026-01-01T00:00:00Z" }
		],
		"expect": {
			"states": {
				"cart-1": { "items": 2 },
				"cart-2": { "items": 1 }
			}
		}
	},
	{
		"name": "partitionBy custom key",
		"source": "fromAll().partitionBy(function(e) { return e.data.region; }).when({ $init() { return { count: 0 }; }, Event(s, e) { s.count++; return s; } })",
		"events": [
			{ "eventType": "Event", "streamId": "s-1", "sequenceNumber": 0, "data": "{\"region\":\"eu\"}", "isJson": true, "eventId": "00000000-0000-0000-0000-000000000000", "created": "2026-01-01T00:00:00Z" },
			{ "eventType": "Event", "streamId": "s-2", "sequenceNumber": 1, "data": "{\"region\":\"us\"}", "isJson": true, "eventId": "00000000-0000-0000-0000-000000000000", "created": "2026-01-01T00:00:00Z" },
			{ "eventType": "Event", "streamId": "s-3", "sequenceNumber": 2, "data": "{\"region\":\"eu\"}", "isJson": true, "eventId": "00000000-0000-0000-0000-000000000000", "created": "2026-01-01T00:00:00Z" }
		],
		"expect": {
			"states": {
				"eu": { "count": 2 },
				"us": { "count": 1 }
			}
		}
	},
	{
		"name": "set and restore state",
		"source": "fromAll().when({ $init() { return { count: 0 }; }, Ping(s, e) { s.count++; return s; } })",
		"setState": { "partition": null, "state": "{\"count\":10}" },
		"events": [
			{ "eventType": "Ping", "streamId": "s-1", "sequenceNumber": 0, "data": "{}", "isJson": true, "eventId": "00000000-0000-0000-0000-000000000000", "created": "2026-01-01T00:00:00Z" }
		],
		"expect": {
			"state": { "count": 11 }
		}
	},
	{
		"name": "set and restore partitioned state",
		"source": "fromAll().foreachStream().when({ $init() { return { count: 0 }; }, Ping(s, e) { s.count++; return s; } })",
		"setState": { "partition": "s-1", "state": "{\"count\":5}" },
		"events": [
			{ "eventType": "Ping", "streamId": "s-1", "sequenceNumber": 0, "data": "{}", "isJson": true, "eventId": "00000000-0000-0000-0000-000000000000", "created": "2026-01-01T00:00:00Z" }
		],
		"expect": {
			"states": {
				"s-1": { "count": 6 }
			}
		}
	},
	{
		"name": "biState with shared state",
		"source": "options({ biState: true }); fromAll().when({ $init() { return { count: 0 }; }, $initShared() { return { total: 0 }; }, Added(s, e) { s[0].count++; s[1].total += e.data.amount; return s; } })",
		"events": [
			{ "eventType": "Added", "streamId": "s-1", "sequenceNumber": 0, "data": "{\"amount\":10}", "isJson": true, "eventId": "00000000-0000-0000-0000-000000000000", "created": "2026-01-01T00:00:00Z" },
			{ "eventType": "Added", "streamId": "s-1", "sequenceNumber": 1, "data": "{\"amount\":20}", "isJson": true, "eventId": "00000000-0000-0000-0000-000000000000", "created": "2026-01-01T00:00:00Z" }
		],
		"expect": {
			"state": { "count": 2 },
			"sharedState": { "total": 30 }
		}
	},
	{
		"name": "state with nested objects",
		"source": "fromAll().when({ $init() { return { users: {}, count: 0 }; }, UserCreated(s, e) { s.users[e.data.id] = { name: e.data.name }; s.count++; return s; } })",
		"events": [
			{ "eventType": "UserCreated", "streamId": "s-1", "sequenceNumber": 0, "data": "{\"id\":\"u1\",\"name\":\"Alice\"}", "isJson": true, "eventId": "00000000-0000-0000-0000-000000000000", "created": "2026-01-01T00:00:00Z" },
			{ "eventType": "UserCreated", "streamId": "s-1", "sequenceNumber": 1, "data": "{\"id\":\"u2\",\"name\":\"Bob\"}", "isJson": true, "eventId": "00000000-0000-0000-0000-000000000000", "created": "2026-01-01T00:00:00Z" }
		],
		"expect": {
			"state": {
				"users": { "u1": { "name": "Alice" }, "u2": { "name": "Bob" } },
				"count": 2
			}
		}
	},
	{
		"name": "state with arrays",
		"source": "fromAll().when({ $init() { return { items: [] }; }, Added(s, e) { s.items.push(e.data.item); return s; } })",
		"events": [
			{ "eventType": "Added", "streamId": "s-1", "sequenceNumber": 0, "data": "{\"item\":\"apple\"}", "isJson": true, "eventId": "00000000-0000-0000-0000-000000000000", "created": "2026-01-01T00:00:00Z" },
			{ "eventType": "Added", "streamId": "s-1", "sequenceNumber": 1, "data": "{\"item\":\"banana\"}", "isJson": true, "eventId": "00000000-0000-0000-0000-000000000000", "created": "2026-01-01T00:00:00Z" }
		],
		"expect": {
			"state": { "items": ["apple", "banana"] }
		}
	},
	{
		"name": "unknown partition returns null",
		"source": "fromAll().foreachStream().when({ $init() { return {}; }, Ping(s, e) { return s; } })",
		"events": [
			{ "eventType": "Ping", "streamId": "s-1", "sequenceNumber": 0, "data": "{}", "isJson": true, "eventId": "00000000-0000-0000-0000-000000000000", "created": "2026-01-01T00:00:00Z" }
		],
		"expect": {
			"states": {
				"s-1": {},
				"nonexistent": null
			}
		}
	},
