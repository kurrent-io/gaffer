default:
    @just --list

# Install dependencies
init:
    pnpm install

# Build the extension
build:
    pnpm run build

# Watch mode for development
watch:
    pnpm run watch

# Run tests
test:
    pnpm run test

# Type check, lint, and format check
check:
    pnpm run check

# Format code and apply lint fixes
fix:
    pnpm run fix

# Build and package as .vsix
package:
    pnpm run package

# Remove built artifacts
clean:
    rm -rf dist *.vsix
