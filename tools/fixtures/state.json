	{
		"name": "events from multiple streams to same projection",
		"source": "fromAll().when({ $init() { return { streams: {} }; }, Ping(s, e) { s.streams[e.streamId] = (s.streams[e.streamId] || 0) + 1; return s; } })",
		"events": [
			{ "eventType": "Ping", "streamId": "a", "sequenceNumber": 0, "data": "{}", "isJson": true, "eventId": "00000000-0000-0000-0000-000000000000", "created": "2026-01-01T00:00:00Z" },
			{ "eventType": "Ping", "streamId": "b", "sequenceNumber": 1, "data": "{}", "isJson": true, "eventId": "00000000-0000-0000-0000-000000000000", "created": "2026-01-01T00:00:00Z" },
			{ "eventType": "Ping", "streamId": "a", "sequenceNumber": 2, "data": "{}", "isJson": true, "eventId": "00000000-0000-0000-0000-000000000000", "created": "2026-01-01T00:00:00Z" }
