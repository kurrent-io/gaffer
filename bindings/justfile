default:
    @just --list

# Install all binding dependencies
[parallel]
init: go::init js::init

# Build platform packages and JS bindings (requires `just runtime publish` first)
[parallel]
build: js::build js-linux-x64::build

# Run all binding tests
[parallel]
test: go::test js::test

# Format all bindings and apply lint fixes
[parallel]
fix: go::fix js::fix

# Check all binding formatting and linting
[parallel]
check: go::check js::check

# Remove build artifacts
[parallel]
clean: js::clean js-linux-x64::clean

mod go
mod js
mod js-linux-x64 'js/native/linux-x64'
