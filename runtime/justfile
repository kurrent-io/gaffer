default:
    @just --list

# Restore NuGet packages
init:
    dotnet restore

# Build the runtime
build:
    dotnet build

# Run tests
test:
    dotnet test --verbosity quiet

# Format code and apply lint fixes
fix:
    dotnet format

# Check formatting without changes
check:
    dotnet format --verify-no-changes

# .NET runtime identifier for the current host. CI overrides this by
# passing an explicit RID to `publish`.
host-rid := if os() == "macos" {
        if arch() == "aarch64" { "osx-arm64" } else { "osx-x64" }
    } else if os() == "windows" {
        "win-x64"
    } else if arch() == "aarch64" {
        "linux-arm64"
    } else {
        "linux-x64"
    }

# Publish NativeAOT shared library. Defaults to host RID; pass an explicit
# RID (linux-x64, linux-arm64, osx-x64, osx-arm64, win-x64) for cross builds.
publish rid=host-rid:
    dotnet publish Gaffer.Runtime -c Release -r {{rid}}

# Remove build artifacts
clean:
    rm -rf Gaffer.Runtime/bin Gaffer.Runtime/obj Gaffer.Runtime.Tests/bin Gaffer.Runtime.Tests/obj Gaffer.Sdk/bin Gaffer.Sdk/obj
