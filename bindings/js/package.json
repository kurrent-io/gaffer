{
	"name": "@kurrent/gaffer-runtime",
	"version": "0.0.1",
	"description": "Node.js bindings for the Gaffer projection runtime",
	"type": "module",
	"main": "src/index.ts",
	"types": "src/index.ts",
	"publishConfig": {
		"main": "dist/src/index.js",
		"types": "dist/src/index.d.ts"
	},
	"scripts": {
		"build": "tsc",
		"test": "vitest run",
		"check": "tsc --noEmit && eslint . && prettier --check .",
		"fix": "eslint --fix . && prettier --write ."
	},
	"engines": {
		"node": ">=22"
	},
	"dependencies": {
		"koffi": "^2.16.1"
	},
	"optionalDependencies": {
		"@kurrent/gaffer-runtime-linux-x64": "workspace:*"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/node": "^25.6.0",
		"eslint": "^10.2.1",
		"prettier": "^3.8.3",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.1",
		"vitest": "^4.1.5"
	}
}
