default:
    @just --list

# Install Go binding tooling. JS bindings have no module-local install
# step - pnpm runs once at the repo root via `just init`.
init: go::init

# Build platform packages and JS bindings (requires `just runtime publish` first)
[parallel]
build: js::build js-linux-x64::build

# Run all binding tests
[parallel]
test: go::test js::test

# Format all bindings and apply lint fixes
[parallel]
fix: go::fix js::fix

# Check all binding formatting and linting
[parallel]
check: go::check js::check

# Remove build artifacts
[parallel]
clean: js::clean js-linux-x64::clean js-linux-arm64::clean js-darwin-x64::clean js-darwin-arm64::clean js-win32-x64::clean

mod go
mod js
mod js-linux-x64 'js/native/linux-x64'
mod js-linux-arm64 'js/native/linux-arm64'
mod js-darwin-x64 'js/native/darwin-x64'
mod js-darwin-arm64 'js/native/darwin-arm64'
mod js-win32-x64 'js/native/win32-x64'
