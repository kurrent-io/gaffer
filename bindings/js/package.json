{
	"name": "@kurrent/gaffer-runtime",
	"version": "0.1.2",
	"description": "Node.js bindings for the Gaffer projection runtime",
	"license": "LicenseRef-KurrentLicenseV1",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kurrent-io/gaffer.git",
		"directory": "bindings/js"
	},
	"homepage": "https://github.com/kurrent-io/gaffer#readme",
	"bugs": {
		"url": "https://github.com/kurrent-io/gaffer/issues"
	},
	"type": "module",
	"main": "src/index.ts",
	"types": "src/index.ts",
	"publishConfig": {
		"main": "dist/src/index.js",
		"types": "dist/src/index.d.ts"
	},
	"files": [
		"CHANGELOG.md",
		"dist"
	],
	"scripts": {
		"build": "tsc",
		"test": "vitest run",
		"check": "tsc --noEmit && eslint . && prettier --check .",
		"fix": "eslint --fix . && prettier --write ."
	},
	"engines": {
		"node": ">=22"
	},
	"dependencies": {
		"koffi": "^2.16.1"
	},
	"optionalDependencies": {
		"@kurrent/gaffer-runtime-darwin-arm64": "workspace:*",
		"@kurrent/gaffer-runtime-darwin-x64": "workspace:*",
		"@kurrent/gaffer-runtime-linux-arm64": "workspace:*",
		"@kurrent/gaffer-runtime-linux-x64": "workspace:*",
		"@kurrent/gaffer-runtime-win32-x64": "workspace:*"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/node": "^25.9.1",
		"eslint": "^10.4.0",
		"prettier": "^3.8.3",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.4",
		"vitest": "^4.1.7"
	}
}
