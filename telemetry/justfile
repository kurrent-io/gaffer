default:
    @just --list

# Pinned tool versions. Bump in lockstep across local/CI by editing here.
cue_version := "v0.14.2"

# Install cue. JS deps install at workspace root via `just init`. The
# Go helper generator is in-tree (telemetry/scripts/gen-helpers) so it
# doesn't need a separate install.
init:
    @go install cuelang.org/go/cmd/cue@{{cue_version}}

# Generate all artifacts from schemas/, then build the worker. Order: cue
# produces the jsonschema (consumed by the worker for runtime validation and
# by the TS generator), the Go helper generator produces typed Tx wrappers
# direct from CUE, the TS generator produces wire types for the worker.
build: _gen-schema _gen-helpers _gen-ts worker::build

# Format the CUE source and the worker's TS / config files.
fix: worker::fix
    @cue fmt schemas/events.cue schemas/wire.cue

# Verify the CUE source is formatted and well-formed; check the worker too.
check: worker::check
    @cue fmt --check schemas/events.cue schemas/wire.cue
    @cue vet schemas/events.cue schemas/wire.cue

# Determinism check: regenerate twice, fail if outputs differ. Catches
# non-deterministic generator output (sort order, timestamps, ...). All
# three Go gen files plus the TS / JSON Schema outputs need stashing so
# a non-determinism bug in any one of them fails CI.
test: build
    @cp generated/telemetry.schema.json /tmp/telemetry-determinism.json
    @cp ../cli/internal/telemetry/events.gen.go /tmp/telemetry-determinism-events.go
    @cp ../cli/internal/telemetry/tx.gen.go /tmp/telemetry-determinism-tx.go
    @cp ../cli/internal/telemetry/emit.gen.go /tmp/telemetry-determinism-emit.go
    @cp generated/events.gen.ts /tmp/telemetry-determinism.ts
    @just clean
    @just build
    @diff /tmp/telemetry-determinism.json generated/telemetry.schema.json
    @diff /tmp/telemetry-determinism-events.go ../cli/internal/telemetry/events.gen.go
    @diff /tmp/telemetry-determinism-tx.go ../cli/internal/telemetry/tx.gen.go
    @diff /tmp/telemetry-determinism-emit.go ../cli/internal/telemetry/emit.gen.go
    @diff /tmp/telemetry-determinism.ts generated/events.gen.ts
    @rm -f /tmp/telemetry-determinism.json /tmp/telemetry-determinism-events.go /tmp/telemetry-determinism-tx.go /tmp/telemetry-determinism-emit.go /tmp/telemetry-determinism.ts
    @GOWORK=off go -C scripts/gen-helpers test ./...

# Remove generated artifacts.
clean: worker::clean
    @rm -f generated/telemetry.schema.json ../cli/internal/telemetry/events.gen.go ../cli/internal/telemetry/tx.gen.go ../cli/internal/telemetry/emit.gen.go generated/events.gen.ts

# CUE -> JSON Schema.
#
# CUE's CLI exposes OpenAPI but not JSON Schema directly. They carry the same
# shapes; we wrap components.schemas as `definitions` (Draft 7-style, the most
# broadly supported across our consumers - json-schema-to-typescript, Ajv) and
# rewrite $refs from #/components/schemas/ to #/definitions/.
#
# Final jq pass hoists `required` arrays out of `allOf` to the top level on
# each variant. CUE's struct-embedding (`{ #Base, extras }`) produces an
# OpenAPI shape with `allOf: [..., {required: [...]}]`, which
# json-schema-to-typescript does NOT walk to determine required-ness (it
# leaves narrowed fields optional). Hoisting fixes the TS output without
# changing the wire shape.
[private]
_gen-schema:
    @mkdir -p generated
    @cue def -o openapi:- schemas/events.cue schemas/wire.cue \
        | jq '.components.schemas.Envelope + {"definitions": .components.schemas, "title": "Envelope"}' \
        | sed 's|#/components/schemas/|#/definitions/|g' \
        | jq '.definitions |= with_entries(.value |= (if (.allOf // []) | any(.required) then .required = ((.required // []) + ([.allOf[] | .required // empty] | flatten) | unique) | .allOf = [.allOf[] | select(.required == null)] | if (.allOf | length == 0) then del(.allOf) else . end else . end))' \
        | jq 'walk(if type == "object" and .type == "object" and (.unevaluatedProperties == null) then . + {unevaluatedProperties: false} elif type == "object" and .type == "array" and (.maxItems == null) then . + {maxItems: 100} else . end) | . + {"$schema": "https://json-schema.org/draft/2019-09/schema"}' \
        > generated/telemetry.schema.json

# CUE -> Go helper types (Envelope, Context, enums, RawCount, per-event
# property structs, per-command Tx wrappers with typed setters). Direct from
# CUE via cuelang.org/go - subsumes the previous JSON-Schema->Go route which
# went through atombender/go-jsonschema. The generator lives in
# scripts/gen-helpers/ as its own Go module (its cuelang.org/go dep stays out
# of the cli module). GOWORK=off lets `go run` work without adding the
# generator to go.work.
[private]
_gen-helpers:
    @GOWORK=off go -C scripts/gen-helpers run . -schemas ../../schemas -out ../../../cli/internal/telemetry/events.gen.go

# JSON Schema -> TypeScript types.
[private]
_gen-ts: _gen-schema
    @pnpm exec json2ts generated/telemetry.schema.json -o generated/events.gen.ts

mod worker
