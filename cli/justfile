default:
    @just --list

# Executable file extension for the current host. `go build -o NAME`
# preserves NAME verbatim, so we explicitly append .exe on Windows.
exe-suffix := if os() == "windows" { ".exe" } else { "" }

# Copy canonical files into the embed tree before go build/test sees
# them. Today this is just cli/TELEMETRY.md, served by the MCP server
# at gaffer://telemetry/info; the copy is gitignored so there's a
# single tracked source of truth.
[private]
_resources:
    cp TELEMETRY.md internal/mcpserver/resources/telemetry-info.gen.md

# Build the CLI binary. Default builds point at the staging telemetry
# worker; use `build-release` to bake the prod URL + version in for
# shippable artefacts. The `dev` build tag adds a build-dir rpath to
# the cgo link so the binary finds the runtime without it being
# co-located - see bindings/go/gaffer_dev.go.
build: _resources
    CGO_ENABLED=1 go build -tags dev -o gaffer{{exe-suffix}} .

# Build the CLI for release: stamps the version and switches the
# telemetry sink to production. No `dev` tag - the shipped binary's
# rpath is co-location only, so it doesn't leak the build-machine
# path. Invoked by the publish pipeline; the version argument comes
# from changesets/action's published packages. The prod ingest URL is
# also hard-coded in editors/vscode/vite.config.ts (as
# `PRODUCTION_INGEST_URL`); keep them in lockstep if the worker URL
# ever moves.
build-release version: _resources
    CGO_ENABLED=1 go build -ldflags '-X github.com/kurrent-io/gaffer/cli/cmd.Version={{version}} -X github.com/kurrent-io/gaffer/cli/internal/telemetry.DefaultWorkerURL=https://telemetry.gaffer.kurrent.io/v1/ingest' -o gaffer{{exe-suffix}} .

# Run tests
test: _resources
    go test -tags dev ./...

# Run integration tests (requires KurrentDB)
test-integration: _resources
    go test -tags 'dev integration' ./...

# Run the CLI
run *args: _resources
    CGO_ENABLED=1 go run -tags dev . {{args}}

# Generate the single Markdown CLI command reference from the cobra
# command tree. Run after touching any command, flag, or description
# so the published reference stays in step with the binary.
gen-docs out-file="../docs/cli/commands.md": _resources
    CGO_ENABLED=1 go run -tags dev ./cmd/docgen {{out-file}}

# Format code and apply lint fixes
fix: _resources
    golangci-lint fmt

# Run linter
check: _resources
    golangci-lint run --allow-parallel-runners

# Remove build artifacts
clean: linux-x64::clean linux-arm64::clean darwin-x64::clean darwin-arm64::clean win32-x64::clean
    rm -f gaffer gaffer.exe
    rm -f internal/mcpserver/resources/*.gen.md

mod linux-x64 'native/linux-x64'
mod linux-arm64 'native/linux-arm64'
mod darwin-x64 'native/darwin-x64'
mod darwin-arm64 'native/darwin-arm64'
mod win32-x64 'native/win32-x64'
