{
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["ES2022", "ESNext.Disposable"],
		"module": "Node16",
		"moduleResolution": "Node16",
		"outDir": "dist",
		"rootDir": ".",
		"declaration": true,
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true
	},
	"include": ["src/**/*", "tests/**/*"]
}
