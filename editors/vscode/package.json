{
  "name": "gaffer",
  "displayName": "Gaffer",
  "description": "KurrentDB projection toolkit",
  "version": "0.0.1",
  "publisher": "kurrent-io",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Debuggers", "Other"],
  "activationEvents": [
    "onDebugResolve:gaffer",
    "workspaceContains:**/gaffer.toml"
  ],
  "main": "./extension.js",
  "devDependencies": {
    "@vscode/vsce": "^3.3.2"
  },
  "contributes": {
    "configuration": {
      "title": "Gaffer",
      "properties": {
        "gaffer.command": {
          "type": "string",
          "default": "gaffer",
          "description": "Command to run gaffer. Use {command} as a placeholder for container/remote setups (e.g. \"devpod ssh gaffer --command \\\"{command}\\\"\")"
        }
      }
    },
    "commands": [
      {
        "command": "gaffer.runProjection",
        "title": "Gaffer: Run Projection"
      },
      {
        "command": "gaffer.debugProjection",
        "title": "Gaffer: Debug Projection"
      }
    ],
    "debuggers": [
      {
        "type": "gaffer",
        "label": "Gaffer",
        "languages": ["javascript"],
        "configurationAttributes": {
          "attach": {
            "properties": {
              "port": {
                "type": "number",
                "description": "DAP server port",
                "default": 4711
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "gaffer",
            "request": "attach",
            "name": "Gaffer Debug",
            "port": 4711
          }
        ]
      }
    ],
    "menus": {
      "commandPalette": [
        { "command": "gaffer.runProjection", "when": "false" },
        { "command": "gaffer.debugProjection", "when": "false" }
      ]
    },
    "breakpoints": [
      { "language": "javascript" }
    ]
  }
}
