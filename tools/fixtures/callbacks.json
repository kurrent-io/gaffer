[
	{
		"name": "emit event",
		"source": "fromAll().when({ $init() { return {}; }, OrderPlaced(s, e) { emit(\"notifications\", \"OrderNotification\", { orderId: e.data.orderId }); return s; } })",
		"events": [
			{
				"eventType": "OrderPlaced",
				"streamId": "order-1",
				"sequenceNumber": 0,
				"data": "{\"orderId\":\"ABC\"}",
				"isJson": true,
				"eventId": "00000000-0000-0000-0000-000000000000",
				"created": "2026-01-01T00:00:00Z"
			}
		],
		"expect": {
			"emitted": [
				{
					"streamId": "notifications",
					"eventType": "OrderNotification",
					"data": "{\"orderId\":\"ABC\"}"
				}
			]
		},
		"options": {
			"engineVersion": 2
		}
	},
