default:
    @just --list

# Build the CLI binary
build:
    CGO_ENABLED=1 go build -o gaffer .

# Run tests
test:
    go test ./...

# Run integration tests (requires KurrentDB)
test-integration:
    go test -tags integration ./...

# Run the CLI
run *args:
    CGO_ENABLED=1 go run . {{args}}

# Format code and apply lint fixes
fix:
    golangci-lint fmt

# Run linter
check:
    golangci-lint run

# Remove build artifacts
clean:
    rm -f gaffer
